{
  "name": "stopwatch-app",
  "version": "1.0.0",
  "description": "Cross-platform stopwatch app (web, iOS, Android) built with React Native",
  "main": "index.js",
  "scripts": {
    "start:web": "webpack serve --mode development --env development",
    "build:web": "webpack --mode production --env production",
    "start:ios": "react-native run-ios",
    "build:ios": "cd ios && xcodebuild -workspace Stopwatch.xcworkspace -scheme Stopwatch -configuration Release -derivedDataPath build",
    "start:android": "react-native run-android",
    "build:android": "cd android && ./gradlew assembleRelease",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,json,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,json,css}'",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules dist build .gradle",
    "clean:all": "npm run clean && rm -rf ios/Pods android/.gradle"
  },
  "dependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/stack": "^6.3.0",
    "ajv": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^19.2.4",
    "react-native": "^0.73.0",
    "react-native-gesture-handler": "^2.15.0",
    "react-native-paper": "^5.11.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.29.0",
    "react-native-sound": "^0.11.2",
    "react-native-vector-icons": "^10.0.0",
    "react-native-web": "^0.19.0",
    "react-test-renderer": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.0",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-typescript": "^7.23.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@react-native/babel-preset": "^0.73.0",
    "@react-native/metro-config": "^0.73.0",
    "@react-native/typescript-config": "^0.73.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.0.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.55.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "metro": "^0.80.0",
    "metro-core": "^0.80.0",
    "metro-resolver": "^0.80.0",
    "mini-css-extract-plugin": "^2.7.0",
    "pod-install": "^0.2.0",
    "prettier": "^3.1.0",
    "style-loader": "^3.3.0",
    "typescript": "^5.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
